# Supabase connection for the EnforcementPOC project.
# Copy this file to `.env.local` and fill in values from the Supabase
# project settings (Project Settings -> API). Both must be set for the
# frontend to use live data; otherwise it falls back to bundled mock data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public base URL of the deployed app. Used to build the magic-link auth
# redirect so links always come back to the deployed site instead of
# localhost. Set this in the Netlify environment for production:
#   VITE_APP_BASE_URL=https://bramptonpoc.netlify.app
# When unset, the app falls back to window.location.origin.
VITE_APP_BASE_URL=

# Anthropic API key for the "AI assisted staff review" feature.
# SERVER SIDE ONLY. This is read exclusively by the Netlify function
# netlify/functions/generate-case-ai-review.ts via process.env. It must never
# be exposed to the browser: do NOT prefix it with VITE_ and never create
# VITE_ANTHROPIC_API_KEY. Set this only in the Netlify environment.
ANTHROPIC_API_KEY=

# Brevo (transactional email) for the Resident Intake Demo flow.
# SERVER SIDE ONLY. BREVO_API_KEY is read exclusively by the Netlify function
# netlify/functions/send-resident-email.ts via process.env. It must never be
# exposed to the browser: do NOT prefix it with VITE_ and never create
# VITE_BREVO_API_KEY. Set this only in the Netlify environment.
BREVO_API_KEY=

# The "from" address for resident emails. Must be a verified sender in the Brevo
# account. Optional name override. Set these in the Netlify environment.
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# Staff notification recipient. When a resident submits a request, a "new
# request" notification is emailed to THIS address (server-owned — it is never
# taken from the public form). Leave unset to disable staff notifications.
BREVO_NOTIFY_EMAIL=

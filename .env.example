# Supabase connection for the EnforcementPOC project.
# Copy this file to `.env.local` and fill in values from the Supabase
# project settings (Project Settings -> API). Both must be set for the
# frontend to use live data; otherwise it falls back to bundled mock data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public base URL of the deployed app. Used to build the magic-link auth
# redirect so links always come back to the deployed site instead of
# localhost. Set this in the Netlify environment for production:
#   VITE_APP_BASE_URL=https://bramptonpoc.netlify.app
# When unset, the app falls back to window.location.origin.
VITE_APP_BASE_URL=

# Anthropic API key for the "AI assisted staff review" feature.
# SERVER SIDE ONLY. This is read exclusively by the Netlify function
# netlify/functions/generate-case-ai-review.ts via process.env. It must never
# be exposed to the browser: do NOT prefix it with VITE_ and never create
# VITE_ANTHROPIC_API_KEY. Set this only in the Netlify environment.
ANTHROPIC_API_KEY=

# Mailjet (transactional email) for the Resident Intake Demo flow.
# SERVER SIDE ONLY. These are read exclusively by the Netlify function
# netlify/functions/send-resident-email.ts via process.env (HTTP Basic Auth:
# public key as username, secret key as password). They must never be exposed to
# the browser: do NOT prefix them with VITE_. Set these only in the Netlify
# environment.
MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=

# The "from" address for resident emails. Must be a validated sender (or domain)
# in the Mailjet account. Optional name override. Set these in the Netlify
# environment. Only the resident is ever emailed (confirmation + a message on
# each staff-driven status change); staff receive no email.
MAILJET_SENDER_EMAIL=
MAILJET_SENDER_NAME=

# Public base URL used to build the "Track request status" link in resident
# emails (netlify/functions/send-resident-email.ts). When unset, the function
# falls back to the Netlify deploy URLs (URL, then DEPLOY_PRIME_URL) and finally
# to https://bramptonpoc.netlify.app.
PUBLIC_SITE_URL=https://bramptonpoc.netlify.app

# AI assisted similar case retrieval (the first AI retrieval feature).
# SERVER SIDE ONLY. Read exclusively by the Netlify function
# netlify/functions/similar-cases.ts and the indexing script
# scripts/index_closed_cases_qdrant.py via process.env / os.environ. They must
# never be exposed to the browser: do NOT prefix any of these with VITE_.
#
# COHERE_API_KEY      — Cohere key used for embeddings (embed-english-v3.0) and
#                       reranking (rerank-english-v3.0).
# QDRANT_URL          — Base URL of the Qdrant instance (e.g.
#                       https://YOUR-cluster.qdrant.io:6333 or http://localhost:6333).
# QDRANT_API_KEY      — Qdrant API key (omit for an unsecured local instance).
# QDRANT_COLLECTION   — Collection name for the indexed historical closed cases.
#                       Defaults to "nyc_closed_cases" when unset.
COHERE_API_KEY=
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=nyc_closed_cases

# Officer Case Assistant (Cohere Command) — the case-scoped officer assistant.
# SERVER SIDE ONLY. Read exclusively by the Netlify function
# netlify/functions/officer-case-assistant.ts via process.env. It reuses
# COHERE_API_KEY above and additionally needs a Cohere Command chat model id.
# Set EITHER variable (COHERE_COMMAND_MODEL takes precedence); if the key or the
# model is missing the function returns a calm 503 and the UI shows a "not
# configured" state. Never expose any Cohere value through a VITE_ variable.
#   COHERE_COMMAND_MODEL — Cohere Command chat model id, e.g. command-r-08-2024.
#   COHERE_CHAT_MODEL    — alternative name for the same value.
COHERE_COMMAND_MODEL=command-r-08-2024
COHERE_CHAT_MODEL=

# Minimum Cohere rerank relevance (0..1) a benchmark reference must score before
# it is passed into the Officer Case Assistant's Command model and surfaced as a
# grounded benchmark note. Weaker references are dropped so benchmark notes stay
# anchored to genuinely comparable cases. Optional — defaults to 0.3.
COHERE_RERANK_MIN=0.3

# The indexing script ALSO reads the historical closed cases from Supabase, and
# the Officer Case Assistant function uses these SERVER-SIDE credentials to
# resolve the authenticated staff identity (from the Supabase access token) and
# to read the case + workflow timeline with the service role key. When unset,
# the Officer Case Assistant degrades to a clearly-marked POC-only path.
# SERVER SIDE ONLY — never VITE_ prefixed, never committed.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
